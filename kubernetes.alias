for loopvar in {1..200}
do
        echo loop : $loopvar
        curl http://10.101.78.136:3000/hostname
        echo "  "
done


# Expose Load BLANCER
# see minikube tunnel
kt expose deployment tonyapp-deploy --type=LoadBalancer --name=tonyapp-deploy-load-balancer-service --port=3000 --target-port=3000 --dry-run=client -o yaml > tonyapp-deploy-loadbalancer-service.yaml



